DLL_W32GUICONS       = @DLL_W32GUICONS@
CC                   = @CC@ @CFLAGS_MACHINE@
CFLAGS               = @CFLAGS@
CFLAGS_UNSIGNED_CHAR = @CFLAGS_UNSIGNED_CHAR@
RC                   = @RC@
RCFLAGS              = @RCFLAGS@
LD                   = @LD@
LDFLAGS              = @LDFLAGS@
LDGUILIBS            = @LDGUILIBS@


DLL_NAME = $(DLL_W32GUICONS)
DLL_OBJS = w32_console@OBJ_SUFFIX@ ../EnginePl/os_path@OBJ_SUFFIX@ \
           ../EnginePl/os_error@OBJ_SUFFIX@ ../EnginePl/winsup@OBJ_SUFFIX@
DLL_RES  = w32_console.res


.SUFFIXES:
.SUFFIXES: @OBJ_SUFFIX@ .cpp .c .res .rc $(SUFFIXES)

.cpp@OBJ_SUFFIX@:
	$(CC) -c $(CFLAGS) $(CFLAGS_UNSIGNED_CHAR) $*.cpp

.c@OBJ_SUFFIX@:
	$(CC) -c $(CFLAGS) $(CFLAGS_UNSIGNED_CHAR) $*.c

.rc.res:
	$(RC) $(RCFLAGS) @RC_OUT_NAME_OPT@$*.res $*.rc

all: $(DLL_NAME) w32gc_interf@OBJ_SUFFIX@ win_exe_icon.res

$(DLL_NAME): $(DLL_OBJS) $(DLL_RES)
	$(LD) $(LDFLAGS) @LD_OUT_NAME_OPT@$(DLL_NAME) $(DLL_OBJS) $(DLL_RES) $(LDGUILIBS) @LD_DLL_OPT@

w32_console@OBJ_SUFFIX@: w32_console.c ../EnginePl/win_registry.h

w32gc_interf@OBJ_SUFFIX@: w32gc_interf.c w32gc_interf.h



clean:
	rm -f *@OBJ_SUFFIX@ *.res *.RES $(DLL_NAME) *.lib *.exp *.EXP *.idb *.pdb *.ilk

distclean: clean
