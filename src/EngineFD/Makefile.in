LIB_ENGINE_FD = @LIB_ENGINE_FD@
GPLC          = @GPLC@
CC            = @CC@ @CFLAGS_MACHINE@
CFLAGS        = @CFLAGS@
AR_RC         = @AR_RC@
RANLIB        = @RANLIB@


LIB_NAME = $(LIB_ENGINE_FD)
LIB_OBJS = fd_inst@OBJ_SUFFIX@ fd_range@OBJ_SUFFIX@  fd_unify@OBJ_SUFFIX@


.SUFFIXES:
.SUFFIXES: @OBJ_SUFFIX@ .c .fd $(SUFFIXES)


$(LIB_NAME): $(LIB_OBJS)
	rm -f $(LIB_NAME)
	$(AR_RC)@AR_SEP@$(LIB_NAME) $(LIB_OBJS)
	$(RANLIB) $(LIB_NAME)


.fd@OBJ_SUFFIX@:
	$(GPLC) -c -C '$(CFLAGS)' $*.fd

.c@OBJ_SUFFIX@:
	$(GPLC) -c -C '$(CFLAGS)' $*.c




fd_inst@OBJ_SUFFIX@: fd_inst.h fd_inst.c fd_range.h fd_hook_range.h

fd_range@OBJ_SUFFIX@: fd_range.h fd_hook_range.h fd_range.c

fd_unify@OBJ_SUFFIX@: fd_unify.fd



clean: clean-check
	rm -f *@OBJ_SUFFIX@ *.ilk *.pdb *.pch *.idb *.exp $(LIB_NAME)


distclean: clean clean-check


